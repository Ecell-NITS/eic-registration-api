generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Otp {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  otp       String
  createdAt DateTime @default(now())
}

enum Branch {
  CSE
  EE
  ECE
  EIE
  CE
  ME
}

type Member {
  name  String
  year  Int
  phone String
}

model TheChairmansConclave {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  branch       Branch   @unique
  contactEmail String
  members      Member[]
  createdAt    DateTime @default(now())
}

model StakesAndBusiness {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  branch       Branch   @unique
  contactEmail String
  members      Member[]
  createdAt    DateTime @default(now())
}

model CampusCapitalist {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  branch       Branch   @unique
  contactEmail String
  members      Member[]
  createdAt    DateTime @default(now())
}

model AdoShuffle {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  branch       Branch    @unique
  contactEmail String
  members      Member[]
  videoLink    String?
  posterLink   String?
  createdAt    DateTime  @default(now())
  submittedAt  DateTime?
}

model TheDealroomEscape {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  branch       Branch   @unique
  contactEmail String
  members      Member[]
  createdAt    DateTime @default(now())
}